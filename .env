# ==============================================================================
# GESTOR DE TAREAS - Variables de Entorno Centralizadas
# ------------------------------------------------------------------------------
# IMPORTANTE: Este archivo NO debe subirse al control de versiones (ver .gitignore)
# Los valores aquí son de DESARROLLO. En producción se inyectan vía el orquestador
# (Docker secrets / variables del entorno de despliegue).
# ==============================================================================

# ------------------------------------------------------------------------------
# Seguridad compartida (JWT firmado por users-service y validado por el resto)
# ------------------------------------------------------------------------------
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-en-produccion
JWT_ALGORITHM=HS256
# Expiración del token: 2 horas
JWT_EXPIRATION_MINUTES=120

# ------------------------------------------------------------------------------
# USERS SERVICE
# ------------------------------------------------------------------------------
USERS_SERVICE_PORT=5001
USERS_DATABASE_URL=postgresql://huddle:huddle@localhost:5432/users_db

# ------------------------------------------------------------------------------
# TASKS SERVICE
# ------------------------------------------------------------------------------
TASKS_SERVICE_PORT=5002
TASKS_DATABASE_URL=postgresql://huddle:huddle@localhost:5433/tasks_db
# URL del notifications-service al que tasks-service avisa al completar una tarea
NOTIFICATIONS_SERVICE_URL=http://localhost:5003

# ------------------------------------------------------------------------------
# NOTIFICATIONS SERVICE
# ------------------------------------------------------------------------------
NOTIFICATIONS_SERVICE_PORT=5003
NOTIFICATIONS_DATABASE_URL=postgresql://huddle:huddle@localhost:5434/notifications_db

# ------------------------------------------------------------------------------
# Entorno de ejecución: development | staging | production
# ------------------------------------------------------------------------------
ENVIRONMENT=development
