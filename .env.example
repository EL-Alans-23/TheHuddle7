# ==============================================================================
# GESTOR DE TAREAS - Plantilla de Variables de Entorno
# ------------------------------------------------------------------------------
# Copia este archivo a `.env` y rellena los valores reales:
#     cp .env.example .env
# Este archivo SÍ se versiona; el `.env` real NUNCA.
# ==============================================================================

# --- Seguridad compartida ---
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- Users Service ---
USERS_SERVICE_PORT=5001
USERS_DATABASE_URL=

# --- Tasks Service ---
TASKS_SERVICE_PORT=5002
TASKS_DATABASE_URL=

# --- Notifications Service ---
NOTIFICATIONS_SERVICE_PORT=5003
NOTIFICATIONS_DATABASE_URL=

# --- Entorno ---
ENVIRONMENT=development
